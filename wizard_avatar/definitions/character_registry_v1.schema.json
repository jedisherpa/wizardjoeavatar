{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardjoe.local/schemas/character_registry_v1.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "default_character_id",
    "characters"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "default_character_id": {
      "type": "string",
      "minLength": 1
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "character_id",
          "package",
          "package_sha256"
        ],
        "properties": {
          "character_id": {
            "type": "string",
            "minLength": 1
          },
          "package": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?!/)(?![A-Za-z]:[\\\\/])(?!\\\\\\\\).+$"
          },
          "package_sha256": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
