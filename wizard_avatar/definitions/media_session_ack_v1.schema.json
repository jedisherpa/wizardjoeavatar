{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardjoe.local/schemas/media_session_ack_v1.schema.json",
  "title": "MediaSessionAckV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "connector_session_id", "accepted_sequence", "accepted_media_epoch", "disposition", "wizard_runtime_epoch", "resync_required", "scheduler_state", "error", "capabilities"],
  "properties": {
    "schema_version": {"const": 1},
    "connector_session_id": {"$ref": "#/$defs/uuid_v4"},
    "accepted_sequence": {"$ref": "#/$defs/count"},
    "accepted_media_epoch": {"$ref": "#/$defs/count"},
    "disposition": {"enum": ["accepted", "duplicate", "stale", "rejected", "resync_required", "controller_conflict", "unavailable"]},
    "wizard_runtime_epoch": {"$ref": "#/$defs/id"},
    "resync_required": {"type": "boolean"},
    "scheduler_state": {"enum": ["no_session", "loading_score", "ready", "playing", "paused", "buffering", "seeking", "clock_uncertain", "stopped", "ended", "scoreless", "error"]},
    "error": {
      "oneOf": [
        {"type": "null"},
        {"type": "object", "additionalProperties": false, "required": ["code"], "properties": {"code": {"type": "string", "pattern": "^[a-z][a-z0-9_]{0,63}$"}}}
      ]
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["media_session_schema", "max_snapshot_hz", "supported_rate_milli", "motion_profiles"],
      "properties": {
        "media_session_schema": {"const": 1},
        "max_snapshot_hz": {"type": "integer", "minimum": 1, "maximum": 60},
        "supported_rate_milli": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "integer", "minimum": 1, "maximum": 4000}},
        "motion_profiles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["full", "reduced", "still"]}}
      }
    }
  },
  "$defs": {
    "uuid_v4": {"type": "string", "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"},
    "id": {"type": "string", "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]{0,127}$"},
    "count": {"type": "integer", "minimum": 0, "maximum": 9007199254740991}
  }
}
