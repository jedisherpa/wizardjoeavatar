{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardjoe.local/schemas/reference_avatar_pose_cells.schema.json",
  "title": "WizardJoe Reference Avatar Pose Cells",
  "type": "object",
  "required": ["schema_version", "asset_set_id", "source_manifest", "poses"],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "asset_set_id": {
      "type": "string",
      "minLength": 1
    },
    "source_manifest": {
      "type": "string",
      "minLength": 1
    },
    "canonical": {
      "type": "object",
      "additionalProperties": true
    },
    "palette": {
      "type": "object",
      "required": ["id", "hash", "unique_color_count"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "pattern": "^sha256:[a-f0-9]{64}$"
        },
        "unique_color_count": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": true
    },
    "rows": {
      "type": "integer",
      "minimum": 1
    },
    "margin": {
      "type": "integer",
      "minimum": 0
    },
    "threshold": {
      "type": "number"
    },
    "coverage_threshold": {
      "type": "integer",
      "minimum": 0,
      "maximum": 255
    },
    "quantized_colors": {
      "type": "integer",
      "minimum": 1
    },
    "poses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/pose"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "point": {
      "type": "array",
      "prefixItems": [
        {
          "type": "integer"
        },
        {
          "type": "integer"
        }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "pose": {
      "type": "object",
      "required": [
        "id",
        "source",
        "cols",
        "rows",
        "root_anchor",
        "facing",
        "locomotion",
        "actions",
        "tags",
        "anchors",
        "cells"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "source_size": {
          "$ref": "#/$defs/point"
        },
        "source_crop": {
          "type": "array",
          "items": {
            "type": "integer"
          },
          "minItems": 4,
          "maxItems": 4
        },
        "cols": {
          "type": "integer",
          "minimum": 1
        },
        "rows": {
          "type": "integer",
          "minimum": 1
        },
        "root_anchor": {
          "$ref": "#/$defs/point"
        },
        "facing": {
          "type": "string"
        },
        "locomotion": {
          "type": "string"
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "phase": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "anchors": {
          "type": "object",
          "required": [
            "root",
            "mouth",
            "left_eye",
            "right_eye",
            "left_foot",
            "right_foot",
            "left_hand",
            "right_hand",
            "staff_hand",
            "staff_tip"
          ],
          "additionalProperties": {
            "$ref": "#/$defs/point"
          }
        },
        "cells": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["x", "y", "rgb"],
            "properties": {
              "x": {
                "type": "integer"
              },
              "y": {
                "type": "integer"
              },
              "rgb": {
                "type": "array",
                "items": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 255
                },
                "minItems": 3,
                "maxItems": 3
              },
              "region": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  }
}
