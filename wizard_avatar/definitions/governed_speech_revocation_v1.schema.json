{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardjoe.local/schemas/governed_speech_revocation_v1.schema.json",
  "title": "GovernedSpeechRevocationV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "approval_id", "revocation_generation"],
  "properties": {
    "schema_version": {"type": "integer", "const": 1},
    "approval_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "revocation_generation": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    }
  }
}
