{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardjoe.local/schemas/character_package.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "character_id", "display_name", "renderer", "pose_library", "animation_graph", "default_pose_id", "capabilities"],
  "properties": {
    "schema_version": {"const": 1},
    "character_id": {"type": "string", "minLength": 1},
    "display_name": {"type": "string", "minLength": 1},
    "renderer": {"const": "asciline_square_cells"},
    "pose_library": {"type": "string", "minLength": 1},
    "animation_graph": {"type": "string", "minLength": 1},
    "default_pose_id": {"type": "string", "minLength": 1},
    "capabilities": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
  }
}
