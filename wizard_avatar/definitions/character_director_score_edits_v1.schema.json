{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardjoe.local/schemas/character_director_score_edits_v1.schema.json",
  "title": "ScoreEditsV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "edit_set_id",
    "revision",
    "character_id",
    "package_digest",
    "base_score_sha256",
    "parent_edit_set_sha256",
    "actor",
    "operations",
    "edit_set_sha256"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "edit_set_id": {
      "type": "string",
      "pattern": "^edits:[a-z0-9][a-z0-9._:-]{0,121}$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "character_id": {"$ref": "#/$defs/id"},
    "package_digest": {"$ref": "#/$defs/hash"},
    "base_score_sha256": {"$ref": "#/$defs/hash"},
    "parent_edit_set_sha256": {"$ref": "#/$defs/nullableHash"},
    "actor": {"$ref": "#/$defs/actor"},
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 256,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/operation"}
    },
    "edit_set_sha256": {"$ref": "#/$defs/hash"}
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:-]{0,127}$"
    },
    "hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "nullableHash": {
      "oneOf": [
        {"type": "null"},
        {"$ref": "#/$defs/hash"}
      ]
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "actor_id"],
      "properties": {
        "kind": {"enum": ["human", "system", "migration"]},
        "actor_id": {"$ref": "#/$defs/id"}
      }
    },
    "operation": {
      "oneOf": [
        {"$ref": "#/$defs/timingOffsetEdit"},
        {"$ref": "#/$defs/durationEdit"},
        {"$ref": "#/$defs/intensityEdit"},
        {"$ref": "#/$defs/semanticClipEdit"},
        {"$ref": "#/$defs/semanticPoseEdit"},
        {"$ref": "#/$defs/semanticActionEdit"},
        {"$ref": "#/$defs/semanticExpressionEdit"},
        {"$ref": "#/$defs/semanticGazeEdit"}
      ]
    },
    "timingOffsetEdit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "cue_id", "edit_type", "expected_value_sha256", "value", "reason_code"],
      "properties": {
        "operation_id": {"$ref": "#/$defs/id"},
        "cue_id": {"$ref": "#/$defs/id"},
        "edit_type": {"const": "timing_offset_ms"},
        "expected_value_sha256": {"$ref": "#/$defs/hash"},
        "value": {"type": "integer", "minimum": -3600000, "maximum": 3600000},
        "reason_code": {"$ref": "#/$defs/id"}
      }
    },
    "durationEdit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "cue_id", "edit_type", "expected_value_sha256", "value", "reason_code"],
      "properties": {
        "operation_id": {"$ref": "#/$defs/id"},
        "cue_id": {"$ref": "#/$defs/id"},
        "edit_type": {"const": "duration_ms"},
        "expected_value_sha256": {"$ref": "#/$defs/hash"},
        "value": {"type": "integer", "minimum": 1, "maximum": 86400000},
        "reason_code": {"$ref": "#/$defs/id"}
      }
    },
    "intensityEdit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "cue_id", "edit_type", "expected_value_sha256", "value", "reason_code"],
      "properties": {
        "operation_id": {"$ref": "#/$defs/id"},
        "cue_id": {"$ref": "#/$defs/id"},
        "edit_type": {"const": "intensity_milli"},
        "expected_value_sha256": {"$ref": "#/$defs/hash"},
        "value": {"type": "integer", "minimum": 0, "maximum": 1000},
        "reason_code": {"$ref": "#/$defs/id"}
      }
    },
    "semanticClipEdit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "cue_id", "edit_type", "expected_value_sha256", "value", "reason_code"],
      "properties": {
        "operation_id": {"$ref": "#/$defs/id"},
        "cue_id": {"$ref": "#/$defs/id"},
        "edit_type": {"const": "semantic_clip_id"},
        "expected_value_sha256": {"$ref": "#/$defs/hash"},
        "value": {"type": "string", "pattern": "^semantic:clip:(?!(?:asset_|cell_|frame_|node_|pixel_|raw_|render_|renderer_|rgba_|sprite_))[a-z0-9][a-z0-9._-]{0,95}$"},
        "reason_code": {"$ref": "#/$defs/id"}
      }
    },
    "semanticPoseEdit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "cue_id", "edit_type", "expected_value_sha256", "value", "reason_code"],
      "properties": {
        "operation_id": {"$ref": "#/$defs/id"},
        "cue_id": {"$ref": "#/$defs/id"},
        "edit_type": {"const": "semantic_pose_id"},
        "expected_value_sha256": {"$ref": "#/$defs/hash"},
        "value": {"type": "string", "pattern": "^semantic:pose:(?!(?:asset_|cell_|frame_|node_|pixel_|raw_|render_|renderer_|rgba_|sprite_))[a-z0-9][a-z0-9._-]{0,95}$"},
        "reason_code": {"$ref": "#/$defs/id"}
      }
    },
    "semanticActionEdit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "cue_id", "edit_type", "expected_value_sha256", "value", "reason_code"],
      "properties": {
        "operation_id": {"$ref": "#/$defs/id"},
        "cue_id": {"$ref": "#/$defs/id"},
        "edit_type": {"const": "semantic_action_id"},
        "expected_value_sha256": {"$ref": "#/$defs/hash"},
        "value": {"type": "string", "pattern": "^semantic:action:(?!(?:asset_|cell_|frame_|node_|pixel_|raw_|render_|renderer_|rgba_|sprite_))[a-z0-9][a-z0-9._-]{0,95}$"},
        "reason_code": {"$ref": "#/$defs/id"}
      }
    },
    "semanticExpressionEdit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "cue_id", "edit_type", "expected_value_sha256", "value", "reason_code"],
      "properties": {
        "operation_id": {"$ref": "#/$defs/id"},
        "cue_id": {"$ref": "#/$defs/id"},
        "edit_type": {"const": "semantic_expression_id"},
        "expected_value_sha256": {"$ref": "#/$defs/hash"},
        "value": {"type": "string", "pattern": "^semantic:expression:(?!(?:asset_|cell_|frame_|node_|pixel_|raw_|render_|renderer_|rgba_|sprite_))[a-z0-9][a-z0-9._-]{0,95}$"},
        "reason_code": {"$ref": "#/$defs/id"}
      }
    },
    "semanticGazeEdit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "cue_id", "edit_type", "expected_value_sha256", "value", "reason_code"],
      "properties": {
        "operation_id": {"$ref": "#/$defs/id"},
        "cue_id": {"$ref": "#/$defs/id"},
        "edit_type": {"const": "semantic_gaze_id"},
        "expected_value_sha256": {"$ref": "#/$defs/hash"},
        "value": {"type": "string", "pattern": "^semantic:gaze:(?!(?:asset_|cell_|frame_|node_|pixel_|raw_|render_|renderer_|rgba_|sprite_))[a-z0-9][a-z0-9._-]{0,95}$"},
        "reason_code": {"$ref": "#/$defs/id"}
      }
    }
  }
}
