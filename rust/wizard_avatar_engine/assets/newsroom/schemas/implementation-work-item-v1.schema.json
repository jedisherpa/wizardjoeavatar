{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wizardjoe.local/schemas/implementation-work-item-v1.schema.json",
  "title": "WizardJoe implementation work item v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "work_item_id",
    "phase",
    "lane",
    "title",
    "dependencies",
    "files",
    "acceptance",
    "human_approval_required",
    "status"
  ],
  "properties": {
    "work_item_id": {
      "type": "string",
      "pattern": "^WJ-[0-9]{3}$"
    },
    "phase": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9
    },
    "lane": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 10
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^WJ-[0-9]{3}$"
      }
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "acceptance": {
      "type": "string",
      "minLength": 20
    },
    "human_approval_required": {
      "type": "boolean"
    },
    "status": {
      "const": "PLANNED_NOT_STARTED"
    }
  }
}
