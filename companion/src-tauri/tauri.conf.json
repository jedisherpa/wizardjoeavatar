{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wizard Joe Companion",
  "version": "0.1.0",
  "identifier": "com.jedisherpa.wizardjoecompanion",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Wizard Joe Companion",
        "width": 1180,
        "height": 780,
        "minWidth": 760,
        "minHeight": 560,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "resources": {
      "resources/sidecar/": "sidecar/"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
